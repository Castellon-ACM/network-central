#. Plugin Name of the plugin.
msgid "Network Central"
msgstr "Network Central"

#. Description of the plugin.
msgid "Enable or disable WordPress Multisite with a single toggle."
msgstr "Activa o desactiva WordPress Multisite con un solo interruptor."

#: network-central.php
msgid "Security check failed."
msgstr "La verificación de seguridad ha fallado."

#: network-central.php
msgid "Permission denied."
msgstr "Permiso denegado."

#: includes/class-network-central-page.php
msgid "WordPress Multisite management"
msgstr "Gestión de WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Multisite enabled successfully. wp-config.php has been updated and the network tables have been created."
msgstr "Multisite activado correctamente. Se ha actualizado wp-config.php y se han creado las tablas de red."

#: includes/class-network-central-page.php
msgid "Multisite disabled. wp-config.php and .htaccess have been restored to single-site."
msgstr "Multisite desactivado. Se ha restaurado wp-config.php y .htaccess a instalación de sitio único."

#: includes/class-network-central-page.php
msgid "wp-config.php is not writable. Fix the file permissions and try again."
msgstr "wp-config.php no tiene permisos de escritura. Corrige los permisos del archivo e inténtalo de nuevo."

#: includes/class-network-central-page.php
msgid "Failed to write wp-config.php or .htaccess. Check file permissions."
msgstr "No se pudo escribir wp-config.php o .htaccess. Comprueba los permisos de los archivos."

#: includes/class-network-central-page.php
msgid "Multisite active"
msgstr "Multisite activo"

#: includes/class-network-central-page.php
msgid "Single site"
msgstr "Sitio único"

#: includes/class-network-central-page.php
msgid "Enable WordPress Multisite"
msgstr "Activar WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Subdirectory install. Writes constants to wp-config.php, updates .htaccess rewrite rules, and creates the network tables."
msgstr "Instalación en subdirectorio. Escribe las constantes en wp-config.php, actualiza las reglas de reescritura de .htaccess y crea las tablas de red."

#: includes/class-network-central-page.php
msgid "wp-config.php is not writable. Fix file permissions to enable this option."
msgstr "wp-config.php no tiene permisos de escritura. Corrige los permisos para activar esta opción."

#: includes/class-network-central-page.php
msgid "Save"
msgstr "Guardar"

#: includes/class-network-central-page.php
msgid "Go to Network Admin"
msgstr "Ir al administrador de red"

#: includes/class-network-central-page.php
msgid "WP_ALLOW_MULTISITE is set but the network is not fully installed yet."
msgstr "WP_ALLOW_MULTISITE está configurado pero la red aún no está completamente instalada."

#: includes/class-network-central-page.php
msgid "Complete the network setup from the WordPress screen."
msgstr "Completa la configuración de red desde la pantalla de WordPress."

#: includes/class-network-central-page.php
msgid "Go to Tools → Network Setup"
msgstr "Ir a Herramientas → Configuración de red"

#: includes/class-network-central-page.php
msgid "System status"
msgstr "Estado del sistema"

#: includes/class-network-central-page.php
msgid "WordPress Multisite"
msgstr "WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Active"
msgstr "Activo"

#: includes/class-network-central-page.php
msgid "Inactive"
msgstr "Inactivo"

#: includes/class-network-central-page.php
msgid "wp-config.php writable"
msgstr "wp-config.php con permisos de escritura"

#: includes/class-network-central-page.php
msgid "Yes"
msgstr "Sí"

#: includes/class-network-central-page.php
msgid "No"
msgstr "No"

#: includes/class-network-central-page.php
msgid ".htaccess writable"
msgstr ".htaccess con permisos de escritura"

#: includes/class-network-central-page.php
msgid "No — manual rewrite rules required"
msgstr "No — se requieren reglas de reescritura manuales"

#: includes/class-network-central-page.php
msgid "PHP version"
msgstr "Versión de PHP"

#: includes/class-network-central-page.php
msgid "WordPress version"
msgstr "Versión de WordPress"
