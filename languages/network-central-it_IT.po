#. Plugin Name of the plugin.
msgid "Network Central"
msgstr "Network Central"

#. Description of the plugin.
msgid "Enable or disable WordPress Multisite with a single toggle."
msgstr "Abilita o disabilita WordPress Multisite con un solo interruttore."

#: network-central.php
msgid "Security check failed."
msgstr "Controllo di sicurezza fallito."

#: network-central.php
msgid "Permission denied."
msgstr "Permesso negato."

#: includes/class-network-central-page.php
msgid "WordPress Multisite management"
msgstr "Gestione di WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Multisite enabled successfully. wp-config.php has been updated and the network tables have been created."
msgstr "Multisite abilitato con successo. wp-config.php è stato aggiornato e le tabelle di rete sono state create."

#: includes/class-network-central-page.php
msgid "Multisite disabled. wp-config.php and .htaccess have been restored to single-site."
msgstr "Multisite disabilitato. wp-config.php e .htaccess sono stati ripristinati al sito singolo."

#: includes/class-network-central-page.php
msgid "wp-config.php is not writable. Fix the file permissions and try again."
msgstr "wp-config.php non è scrivibile. Correggi i permessi del file e riprova."

#: includes/class-network-central-page.php
msgid "Failed to write wp-config.php or .htaccess. Check file permissions."
msgstr "Impossibile scrivere wp-config.php o .htaccess. Controlla i permessi dei file."

#: includes/class-network-central-page.php
msgid "Multisite active"
msgstr "Multisite attivo"

#: includes/class-network-central-page.php
msgid "Single site"
msgstr "Sito singolo"

#: includes/class-network-central-page.php
msgid "Enable WordPress Multisite"
msgstr "Abilita WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Subdirectory install. Writes constants to wp-config.php, updates .htaccess rewrite rules, and creates the network tables."
msgstr "Installazione in sottodirectory. Scrive le costanti in wp-config.php, aggiorna le regole di riscrittura di .htaccess e crea le tabelle di rete."

#: includes/class-network-central-page.php
msgid "wp-config.php is not writable. Fix file permissions to enable this option."
msgstr "wp-config.php non è scrivibile. Correggi i permessi per abilitare questa opzione."

#: includes/class-network-central-page.php
msgid "Save"
msgstr "Salva"

#: includes/class-network-central-page.php
msgid "Go to Network Admin"
msgstr "Vai all'amministrazione di rete"

#: includes/class-network-central-page.php
msgid "WP_ALLOW_MULTISITE is set but the network is not fully installed yet."
msgstr "WP_ALLOW_MULTISITE è impostato ma la rete non è ancora completamente installata."

#: includes/class-network-central-page.php
msgid "Complete the network setup from the WordPress screen."
msgstr "Completa la configurazione della rete dalla schermata di WordPress."

#: includes/class-network-central-page.php
msgid "Go to Tools → Network Setup"
msgstr "Vai in Strumenti → Configurazione rete"

#: includes/class-network-central-page.php
msgid "System status"
msgstr "Stato del sistema"

#: includes/class-network-central-page.php
msgid "WordPress Multisite"
msgstr "WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Active"
msgstr "Attivo"

#: includes/class-network-central-page.php
msgid "Inactive"
msgstr "Inattivo"

#: includes/class-network-central-page.php
msgid "wp-config.php writable"
msgstr "wp-config.php scrivibile"

#: includes/class-network-central-page.php
msgid "Yes"
msgstr "Sì"

#: includes/class-network-central-page.php
msgid "No"
msgstr "No"

#: includes/class-network-central-page.php
msgid ".htaccess writable"
msgstr ".htaccess scrivibile"

#: includes/class-network-central-page.php
msgid "No — manual rewrite rules required"
msgstr "No — regole di riscrittura manuali richieste"

#: includes/class-network-central-page.php
msgid "PHP version"
msgstr "Versione PHP"

#: includes/class-network-central-page.php
msgid "WordPress version"
msgstr "Versione WordPress"
