#. Plugin Name of the plugin.
msgid "Network Central"
msgstr "Network Central"

#. Description of the plugin.
msgid "Enable or disable WordPress Multisite with a single toggle."
msgstr "Ative ou desative o WordPress Multisite com um único interruptor."

#: network-central.php
msgid "Security check failed."
msgstr "Falha na verificação de segurança."

#: network-central.php
msgid "Permission denied."
msgstr "Permissão negada."

#: includes/class-network-central-page.php
msgid "WordPress Multisite management"
msgstr "Gestão do WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Multisite enabled successfully. wp-config.php has been updated and the network tables have been created."
msgstr "Multisite ativado com sucesso. O wp-config.php foi atualizado e as tabelas de rede foram criadas."

#: includes/class-network-central-page.php
msgid "Multisite disabled. wp-config.php and .htaccess have been restored to single-site."
msgstr "Multisite desativado. O wp-config.php e o .htaccess foram restaurados para instalação de site único."

#: includes/class-network-central-page.php
msgid "wp-config.php is not writable. Fix the file permissions and try again."
msgstr "O wp-config.php não tem permissões de escrita. Corrija as permissões do ficheiro e tente novamente."

#: includes/class-network-central-page.php
msgid "Failed to write wp-config.php or .htaccess. Check file permissions."
msgstr "Não foi possível escrever no wp-config.php ou .htaccess. Verifique as permissões dos ficheiros."

#: includes/class-network-central-page.php
msgid "Multisite active"
msgstr "Multisite ativo"

#: includes/class-network-central-page.php
msgid "Single site"
msgstr "Site único"

#: includes/class-network-central-page.php
msgid "Enable WordPress Multisite"
msgstr "Ativar WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Subdirectory install. Writes constants to wp-config.php, updates .htaccess rewrite rules, and creates the network tables."
msgstr "Instalação em subdiretório. Escreve as constantes no wp-config.php, atualiza as regras de reescrita do .htaccess e cria as tabelas de rede."

#: includes/class-network-central-page.php
msgid "wp-config.php is not writable. Fix file permissions to enable this option."
msgstr "O wp-config.php não tem permissões de escrita. Corrija as permissões para ativar esta opção."

#: includes/class-network-central-page.php
msgid "Save"
msgstr "Guardar"

#: includes/class-network-central-page.php
msgid "Go to Network Admin"
msgstr "Ir para a administração de rede"

#: includes/class-network-central-page.php
msgid "WP_ALLOW_MULTISITE is set but the network is not fully installed yet."
msgstr "WP_ALLOW_MULTISITE está definido mas a rede ainda não está completamente instalada."

#: includes/class-network-central-page.php
msgid "Complete the network setup from the WordPress screen."
msgstr "Conclua a configuração da rede a partir do ecrã do WordPress."

#: includes/class-network-central-page.php
msgid "Go to Tools → Network Setup"
msgstr "Ir para Ferramentas → Configuração da rede"

#: includes/class-network-central-page.php
msgid "System status"
msgstr "Estado do sistema"

#: includes/class-network-central-page.php
msgid "WordPress Multisite"
msgstr "WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Active"
msgstr "Ativo"

#: includes/class-network-central-page.php
msgid "Inactive"
msgstr "Inativo"

#: includes/class-network-central-page.php
msgid "wp-config.php writable"
msgstr "wp-config.php com permissões de escrita"

#: includes/class-network-central-page.php
msgid "Yes"
msgstr "Sim"

#: includes/class-network-central-page.php
msgid "No"
msgstr "Não"

#: includes/class-network-central-page.php
msgid ".htaccess writable"
msgstr ".htaccess com permissões de escrita"

#: includes/class-network-central-page.php
msgid "No — manual rewrite rules required"
msgstr "Não — regras de reescrita manuais necessárias"

#: includes/class-network-central-page.php
msgid "PHP version"
msgstr "Versão PHP"

#: includes/class-network-central-page.php
msgid "WordPress version"
msgstr "Versão WordPress"
