#. Plugin Name of the plugin.
msgid "Network Central"
msgstr "Network Central"

#. Description of the plugin.
msgid "Enable or disable WordPress Multisite with a single toggle."
msgstr "Activez ou désactivez WordPress Multisite avec un seul bouton."

#: network-central.php
msgid "Security check failed."
msgstr "La vérification de sécurité a échoué."

#: network-central.php
msgid "Permission denied."
msgstr "Permission refusée."

#: includes/class-network-central-page.php
msgid "WordPress Multisite management"
msgstr "Gestion de WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Multisite enabled successfully. wp-config.php has been updated and the network tables have been created."
msgstr "Multisite activé avec succès. wp-config.php a été mis à jour et les tables réseau ont été créées."

#: includes/class-network-central-page.php
msgid "Multisite disabled. wp-config.php and .htaccess have been restored to single-site."
msgstr "Multisite désactivé. wp-config.php et .htaccess ont été restaurés en site unique."

#: includes/class-network-central-page.php
msgid "wp-config.php is not writable. Fix the file permissions and try again."
msgstr "wp-config.php n'est pas accessible en écriture. Corrigez les permissions du fichier et réessayez."

#: includes/class-network-central-page.php
msgid "Failed to write wp-config.php or .htaccess. Check file permissions."
msgstr "Impossible d'écrire wp-config.php ou .htaccess. Vérifiez les permissions des fichiers."

#: includes/class-network-central-page.php
msgid "Multisite active"
msgstr "Multisite actif"

#: includes/class-network-central-page.php
msgid "Single site"
msgstr "Site unique"

#: includes/class-network-central-page.php
msgid "Enable WordPress Multisite"
msgstr "Activer WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Subdirectory install. Writes constants to wp-config.php, updates .htaccess rewrite rules, and creates the network tables."
msgstr "Installation en sous-répertoire. Écrit les constantes dans wp-config.php, met à jour les règles de réécriture .htaccess et crée les tables réseau."

#: includes/class-network-central-page.php
msgid "wp-config.php is not writable. Fix file permissions to enable this option."
msgstr "wp-config.php n'est pas accessible en écriture. Corrigez les permissions pour activer cette option."

#: includes/class-network-central-page.php
msgid "Save"
msgstr "Enregistrer"

#: includes/class-network-central-page.php
msgid "Go to Network Admin"
msgstr "Aller à l'administration réseau"

#: includes/class-network-central-page.php
msgid "WP_ALLOW_MULTISITE is set but the network is not fully installed yet."
msgstr "WP_ALLOW_MULTISITE est défini mais le réseau n'est pas encore complètement installé."

#: includes/class-network-central-page.php
msgid "Complete the network setup from the WordPress screen."
msgstr "Terminez la configuration du réseau depuis l'écran WordPress."

#: includes/class-network-central-page.php
msgid "Go to Tools → Network Setup"
msgstr "Aller dans Outils → Configuration du réseau"

#: includes/class-network-central-page.php
msgid "System status"
msgstr "État du système"

#: includes/class-network-central-page.php
msgid "WordPress Multisite"
msgstr "WordPress Multisite"

#: includes/class-network-central-page.php
msgid "Active"
msgstr "Actif"

#: includes/class-network-central-page.php
msgid "Inactive"
msgstr "Inactif"

#: includes/class-network-central-page.php
msgid "wp-config.php writable"
msgstr "wp-config.php accessible en écriture"

#: includes/class-network-central-page.php
msgid "Yes"
msgstr "Oui"

#: includes/class-network-central-page.php
msgid "No"
msgstr "Non"

#: includes/class-network-central-page.php
msgid ".htaccess writable"
msgstr ".htaccess accessible en écriture"

#: includes/class-network-central-page.php
msgid "No — manual rewrite rules required"
msgstr "Non — règles de réécriture manuelles requises"

#: includes/class-network-central-page.php
msgid "PHP version"
msgstr "Version PHP"

#: includes/class-network-central-page.php
msgid "WordPress version"
msgstr "Version WordPress"
